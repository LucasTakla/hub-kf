# Database (Neon PostgreSQL recommended)
# Hostinger/shared hosting: add connection_limit=3 to avoid exhausting process/thread limits
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&connection_limit=3"

# Clerk Authentication — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/roadmap"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/roadmap"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/roadmap"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/roadmap"

# App URL (production subdomain)
NEXT_PUBLIC_APP_URL="https://hub.yourdomain.com"

# n8n / automation webhook — POST leads to /api/leads/ingest with header x-api-key
LEADS_INGEST_SECRET="generate-a-long-random-secret"

# GHL deal sync — POST /api/deals/sync with header x-api-key
# Same endpoint for both automations; set action in the JSON body:
#   "opportunity-created" — first time a deal enters the pipeline
#   "stage-changed"       — when reps move a deal in GHL (IDs + stage only is fine)
# Optional override — defaults already match Kapital Funding GHL pipeline stage names
# GHL_STAGE_MAP={"New Lead":"NEW","Attempting contact":"NEW","Connected - Qualifying":"QUALIFIED","Docs requested":"COLLECTING_DOCS","Submitted":"SUBMITTED","Awaiting response":"SUBMITTED","Offer":"NEGOTIATING","Funded":"FUNDED","Declined":"LOST","Dead":"LOST"}
DEALS_SYNC_SECRET=""
GHL_STAGE_MAP=""

# Meta Ads (optional — or connect via Settings → Meta Ads)
# Manual: paste a long-lived token + ad account ID in Settings
# OAuth: set app credentials and add redirect URI {NEXT_PUBLIC_APP_URL}/api/marketing/meta/oauth/callback
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID="act_..."
META_APP_ID=""
META_APP_SECRET=""

# Creative library — video/image storage on Hostinger disk
# Production: create a folder at the DOMAIN ROOT (same level as nodejs/), NOT inside nodejs/
# Example: /home/u254058900/domains/hub.kapitalfunding.co/creatives
# Avoid public_html unless the Node app user has write permission there.
# Dev default: ./public/creatives
CREATIVE_UPLOAD_DIR=""
CREATIVE_MAX_UPLOAD_MB="200"
# After changing CREATIVE_MAX_UPLOAD_MB, set next.config.ts MAX_UPLOAD_BODY to match (requires redeploy).
